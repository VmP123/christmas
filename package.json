{
  "name": "christmas",
  "version": "0.5.0",
  "repository": "",
  "description": "Christmas",
  "keywords": [
    "pixi",
    "pixijs",
    "pixi.js",
    "es6"
  ],
  "scripts": {
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && webpack-dev-server --mode development",
    "webpack": "webpack --mode development",
    "build": "set NODE_OPTIONS=--openssl-legacy-provider && webpack --mode production",
    "format": "find app -name '*.js' | xargs -I{} ./node_modules/.bin/prettier --write --single-quote {}",
    "prewebpack": "npm run clean",
    "clean": "rm -rf ./build && mkdir ./build",
    "lint": "eslint ./app/**/*.js"
  },
  "dependencies": {
    "copy-webpack-plugin": "^4.5.1",
    "pixi-particles": "^3.0.0",
    "pixi.js": "^4.8.2"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/eslint-parser": "^7.11.0",
    "babel-loader": "^8.0.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^2.7.0",
    "eslint-plugin-prettier": "^2.3.1",
    "file-loader": "^1.1.11",
    "prettier": "1.11.1",
    "raw-loader": "^0.5.1",
    "webpack": "^4.26.1",
    "webpack-cli": "^2.0.12",
    "webpack-dev-server": "^3.1.10"
  },
  "engines": {
    "node": ">=8.0.0"
  },
  "plugins": [
    "prettier"
  ]
}
